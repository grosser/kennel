DATADOG_APP_KEY=<insert key here>
DATADOG_API_KEY=<insert key here>
DATADOG_SUBDOMAIN=app
DD_SITE=datadoghq.com

# optional oauth mode:
# DATADOG_AUTH_METHOD=static
# DATADOG_AUTH_METHOD=oauth
# - leave DATADOG_APP_KEY and DATADOG_API_KEY unset to use OAuth via automatic fallback
# - tokens go to the system keychain when available, otherwise ~/.kennel/oauth_auth.json
# DD_TOKEN_STORAGE=file
# DD_TOKEN_STORAGE=keychain
# DD_OAUTH_SCOPES=dashboards_read,dashboards_write,integrations_read,monitors_read,monitors_write,monitors_downtime,slos_read,slos_write,synthetics_read,synthetics_write
# DD_OAUTH_CALLBACK_PORT=8000
# DD_OAUTH_ORG_UUID=
